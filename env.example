# --- APP CONFIG ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_DEFAULT_STORE_ID=default-store-id

# --- CLOUDFLARE (Drizzle & Wrangler) ---
CLOUDFLARE_ACCOUNT_ID=your_account_id
CLOUDFLARE_API_TOKEN=your_api_token
CLOUDFLARE_D1_DATABASE_ID=your_database_id
NEXT_PUBLIC_R2_PUBLIC_URL=http://localhost:3000/r2-local

# --- CLERK AUTHENTICATION ---
# Find these in your Clerk Dashboard -> API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
CLERK_WEBHOOK_SECRET=wh_...

# Clerk URLs (Standard Next.js defaults)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# --- STRIPE PAYMENTS ---
# Find these in your Stripe Dashboard -> Developers -> API keys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# --- RESEND (Email) ---
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=onboarding@resend.dev

# --- ANALYTICS & MONITORING ---
# Sentry, Axiom, etc. (Optional)
# NEXT_PUBLIC_SENTRY_DSN=
